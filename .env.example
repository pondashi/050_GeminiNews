# Gemini API Key for summarizing the data
GEMINI_API_KEY=your_gemini_api_key_here

# Discord or Slack Webhook URL
WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: Target theme for news (Default: 半導体)
TARGET_THEME=半導体

# Optional: Comma-separated list of stock tickers (Default: NVDA,TSM,6920.T)
TARGET_TICKERS=NVDA,TSM,6920.T
